{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Google Ads Debated Proposal",
  "type": "object",
  "required": ["proposal_id", "type", "summary", "options"],
  "properties": {
    "proposal_id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["BUDGET", "OPTIMIZATION", "WASTED_SPEND", "TRACKING_ISSUE", "DIAGNOSE"]
    },
    "summary": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "pending_review",
        "accepted",
        "rejected",
        "ignored",
        "user_marked_implemented",
        "detected_implemented",
        "monitoring_14",
        "monitoring_30",
        "completed",
        "expired",
        "superseded"
      ],
      "default": "pending_review"
    },
    "campaign_id": { "type": ["string", "null"] },
    "campaignId": { "type": ["string", "null"] },
    "selected_option_id": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "created_by": { "type": "string", "enum": ["agent", "deterministic_signal"], "default": "agent" },
    "source_signal_ids": { "type": "array", "items": { "type": "string" } },
    "memory_context": {
      "type": ["object", "null"],
      "description": "Optional. Human-readable semantic memories that materially influenced proposal framing, ranking, or risk. Use only when retrieved memory changed the recommendation.",
      "properties": {
        "summary": { "type": "string" },
        "memories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "memory_id": { "type": "string" },
              "scope_type": { "type": "string" },
              "category": { "type": "string" },
              "authority": { "type": "string" },
              "verification_status": { "type": "string" },
              "content": { "type": "string" },
              "reason": { "type": "string" },
              "influence": { "type": "string" },
              "source_ref": { "type": "string" },
              "valid_until": { "type": ["string", "null"] }
            }
          }
        },
        "caveats": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_window": {
      "type": ["object", "null"],
      "properties": {
        "start": { "type": ["string", "null"] },
        "end": { "type": ["string", "null"] }
      }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["option_id", "strategy_type", "hypothesis", "recommendation", "verification_spec"],
        "properties": {
          "option_id": { "type": "string" },
          "strategy_type": { "type": "string" },
          "hypothesis": { "type": "string" },
          "recommendation": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "counter_evidence": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "manual_steps": { "type": "array", "items": { "type": "string" } },
          "expected_outcome": { "type": "string" },
          "win_probability": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "memory_context": {
            "type": ["object", "null"],
            "description": "Optional option-specific memory context when a retrieved memory changes this option more than the overall proposal.",
            "properties": {
              "summary": { "type": "string" },
              "memories": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "memory_id": { "type": "string" },
                    "scope_type": { "type": "string" },
                    "category": { "type": "string" },
                    "authority": { "type": "string" },
                    "verification_status": { "type": "string" },
                    "content": { "type": "string" },
                    "reason": { "type": "string" },
                    "influence": { "type": "string" },
                    "source_ref": { "type": "string" },
                    "valid_until": { "type": ["string", "null"] }
                  }
                }
              },
              "caveats": { "type": "array", "items": { "type": "string" } }
            }
          },
          "verification_spec": {
            "type": "object",
            "description": "Observable future-state check. Status checks use uppercase Google Ads statuses. budget/Target CPA/manual bid changes use micros. Target ROAS changes use ratio values.",
            "required": ["kind", "observable", "entity", "expected"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "campaign_status",
                  "keyword_status",
                  "keyword_added_exact",
                  "negative_search_term_added",
                  "campaign_budget_changed",
                  "target_cpa_changed",
                  "target_roas_changed",
                  "manual_bid_changed",
                  "diagnosis_only"
                ]
              },
              "observable": { "type": "boolean" },
              "entity": {
                "type": "object",
                "description": "Use campaign_id for campaign-level checks. Add ad_group_id plus criterion_id or keyword_text/match_type for keyword checks. Use search_term for search-term checks."
              },
              "expected": {
                "type": "object",
                "description": "Use status/statuses for status checks. Use value_micros, amount_micros, bid_micros, or previous_*_micros for budget/CPA/bid checks. Use value or previous_value for target_roas_changed."
              }
            }
          }
        }
      }
    }
  }
}
