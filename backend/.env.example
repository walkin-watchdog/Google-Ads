# OAuth 2.0 Credentials (from Google Cloud Console)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Generate GOOGLE_SHEETS_REFRESH_TOKEN with below scopes:
# https://www.googleapis.com/auth/adwords
# https://www.googleapis.com/auth/spreadsheets.readonly
GOOGLE_SHEETS_REFRESH_TOKEN=

# Developer Token (from Google Ads API Centre in Manager Account)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Customer IDs (digits only, no dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1997988556
GOOGLE_ADS_CUSTOMER_ID=

DEPLOYMENT_MODE=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres?schema=public
DATABASE_SSL=disable
STARTUP_REFRESH=true
STARTUP_SERVER_READY_TIMEOUT_MS=60000
SECRET_API_KEY=
LEAD_WEBHOOK_SECRET=

PUBLIC_DASHBOARD_BASE_URL=
SERVE_DASHBOARD_CLIENT=true
DASHBOARD_TRUST_PROXY=false
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_DELIVERY_TIMEOUT_MS=20000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
GOOGLE_ADS_FETCH_TIMEOUT_MS=25000
GOOGLE_ADS_WAREHOUSE_START_DATE=2026-05-06
GOOGLE_ADS_MUTABLE_LOOKBACK_DAYS=90
GOOGLE_ADS_STARTUP_LOOKBACK_DAYS=14
TRIGGER_REFRESH_MIN_INTERVAL_MINUTES=360
DASHBOARD_DB_CACHE_MAX_BYTES=2000000
DASHBOARD_MEMORY_CACHE_SECONDS=600
DASHBOARD_MEMORY_CACHE_MAX_ENTRIES=10
DASHBOARD_MEMORY_CACHE_MAX_BYTES=25000000
DASHBOARD_VIEW_CACHE_SECONDS=60
DASHBOARD_BASE_BUNDLE_CACHE_SECONDS=60
DASHBOARD_FILTER_OPTIONS_CACHE_SECONDS=60
DASHBOARD_KEYWORD_ROW_LIMIT=1500
DASHBOARD_SEARCH_TERM_ROW_LIMIT=2000
DASHBOARD_PLANNER_ROW_LIMIT=1000
DASHBOARD_RANK_KEYWORD_ROW_LIMIT=1000
DASHBOARD_RANK_SEARCH_TERM_ROW_LIMIT=1000
DASHBOARD_LANDING_PAGE_ROW_LIMIT=500
DASHBOARD_AUCTION_INSIGHTS_ROW_LIMIT=1000
DASHBOARD_CANDIDATE_SIGNAL_ROW_LIMIT=250
DASHBOARD_DB_POOL_MAX=4
DASHBOARD_DB_IDLE_TIMEOUT_MS=10000
DASHBOARD_SESSION_TOUCH_INTERVAL_SECONDS=300
GOOGLE_ADS_REFRESH_FETCH_CONCURRENCY=5
