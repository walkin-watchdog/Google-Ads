# HuggingFace Spaces + Neon mode.
DEPLOYMENT_MODE=hf
NODE_ENV=production
PORT=7860

# Neon or another remote PostgreSQL requiring SSL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_SSL=require

SECRET_API_KEY=
MCP_API_KEYS_JSON=
LEAD_WEBHOOK_SECRET=
PUBLIC_DASHBOARD_BASE_URL=https://YOUR_HF_USERNAME-YOUR_SPACE_NAME.hf.space
SERVE_DASHBOARD_CLIENT=true
DASHBOARD_CORS_ORIGINS=
DASHBOARD_TRUST_PROXY=1
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_DELIVERY_TIMEOUT_MS=20000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_SHEETS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

GOOGLE_ADS_WAREHOUSE_START_DATE=2026-05-06
GOOGLE_ADS_MUTABLE_LOOKBACK_DAYS=90
GOOGLE_ADS_STARTUP_LOOKBACK_DAYS=14
STARTUP_REFRESH=true
STARTUP_SERVER_READY_TIMEOUT_MS=60000
GOOGLE_ADS_REFRESH_FETCH_CONCURRENCY=2
GOOGLE_ADS_QUOTA_GOVERNOR_ENABLED=true
GOOGLE_ADS_QUOTA_DEVELOPER_REQUESTS_PER_MINUTE=600
GOOGLE_ADS_QUOTA_CUSTOMER_REQUESTS_PER_MINUTE=300
GOOGLE_ADS_QUOTA_MUTATE_REQUESTS_PER_MINUTE=60
# Google Ads developer-token access level: Basic=15000, Explorer=2880, Standard=0 (unlimited).
GOOGLE_ADS_QUOTA_DEVELOPER_OPERATIONS_PER_24_HOURS=15000
GOOGLE_ADS_QUOTA_MAX_WAIT_MS=120000
GOOGLE_ADS_QUOTA_RESOURCE_EXHAUSTED_PAUSE_MS=60000
GOOGLE_ADS_QUOTA_SHORT_TERM_RESOURCE_EXHAUSTED_PAUSE_MS=300000
GOOGLE_ADS_QUOTA_LONG_TERM_RESOURCE_EXHAUSTED_PAUSE_MS=1800000
TRIGGER_REFRESH_MIN_INTERVAL_MINUTES=360
REFRESH_QUEUE_POLL_INTERVAL_MS=30000
REFRESH_QUEUE_HEARTBEAT_MS=15000
REFRESH_QUEUE_STALE_AFTER_MS=1200000
REFRESH_JOB_TIMEOUT_MS=900000
DASHBOARD_DB_POOL_MAX=4
DASHBOARD_DB_IDLE_TIMEOUT_MS=10000
DASHBOARD_SESSION_TOUCH_INTERVAL_SECONDS=300
