# Copy to .env.vps on the VPS or provide it through the deploy workflow secret.
DEPLOYMENT_MODE=vps
NODE_ENV=production
PORT=7860
HOST_BIND=0.0.0.0
HOST_PORT=7860

# Local PostgreSQL container. Change POSTGRES_PASSWORD before deployment.
POSTGRES_DB=google_ads
POSTGRES_USER=google_ads
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_SSL=disable

# Dashboard/API auth.
SECRET_API_KEY=
MCP_API_KEYS_JSON=
LEAD_WEBHOOK_SECRET=
PUBLIC_DASHBOARD_BASE_URL=http://YOUR_VPS_PUBLIC_IP:7860
SERVE_DASHBOARD_CLIENT=true
DASHBOARD_CORS_ORIGINS=
DASHBOARD_TRUST_PROXY=false
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_DELIVERY_TIMEOUT_MS=20000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# OAuth 2.0 credentials from Google Cloud Console.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_SHEETS_REFRESH_TOKEN=

# Google Ads API credentials.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# First warehouse backfill window.
GOOGLE_ADS_WAREHOUSE_START_DATE=2026-05-06
GOOGLE_ADS_MUTABLE_LOOKBACK_DAYS=30
GOOGLE_ADS_STARTUP_LOOKBACK_DAYS=3

# Micro VPS defaults. Keep startup cheap; refresh manually or with a low-frequency cron.
STARTUP_REFRESH=false
STARTUP_SERVER_READY_TIMEOUT_MS=60000
GOOGLE_ADS_REFRESH_FETCH_CONCURRENCY=1
TRIGGER_REFRESH_MIN_INTERVAL_MINUTES=360
REFRESH_QUEUE_POLL_INTERVAL_MS=30000
REFRESH_QUEUE_HEARTBEAT_MS=15000
REFRESH_QUEUE_STALE_AFTER_MS=1200000
REFRESH_JOB_TIMEOUT_MS=900000
GOOGLE_ADS_FETCH_TIMEOUT_MS=25000
GOOGLE_ADS_QUOTA_GOVERNOR_ENABLED=true
GOOGLE_ADS_QUOTA_DEVELOPER_REQUESTS_PER_MINUTE=120
GOOGLE_ADS_QUOTA_CUSTOMER_REQUESTS_PER_MINUTE=60
GOOGLE_ADS_QUOTA_MUTATE_REQUESTS_PER_MINUTE=20
# Google Ads developer-token access level: Basic=15000, Explorer=2880, Standard=0 (unlimited).
GOOGLE_ADS_QUOTA_DEVELOPER_OPERATIONS_PER_24_HOURS=15000
GOOGLE_ADS_QUOTA_MAX_WAIT_MS=120000
GOOGLE_ADS_QUOTA_RESOURCE_EXHAUSTED_PAUSE_MS=60000
GOOGLE_ADS_QUOTA_SHORT_TERM_RESOURCE_EXHAUSTED_PAUSE_MS=300000
GOOGLE_ADS_QUOTA_LONG_TERM_RESOURCE_EXHAUSTED_PAUSE_MS=1800000

# Small process/DB cache settings for 1 GB RAM machines.
DASHBOARD_DB_POOL_MAX=1
DASHBOARD_DB_IDLE_TIMEOUT_MS=5000
DASHBOARD_SESSION_TOUCH_INTERVAL_SECONDS=300
DASHBOARD_DB_TIMEOUT_MS=30000
DASHBOARD_DB_CACHE_MAX_BYTES=1000000
DASHBOARD_MEMORY_CACHE_SECONDS=300
DASHBOARD_MEMORY_CACHE_MAX_ENTRIES=3
DASHBOARD_MEMORY_CACHE_MAX_BYTES=6000000
DASHBOARD_VIEW_CACHE_SECONDS=30
DASHBOARD_BASE_BUNDLE_CACHE_SECONDS=30
DASHBOARD_FILTER_OPTIONS_CACHE_SECONDS=30
DASHBOARD_KEYWORD_ROW_LIMIT=500
DASHBOARD_SEARCH_TERM_ROW_LIMIT=750
DASHBOARD_PLANNER_ROW_LIMIT=300
DASHBOARD_RANK_KEYWORD_ROW_LIMIT=400
DASHBOARD_RANK_SEARCH_TERM_ROW_LIMIT=400
DASHBOARD_LANDING_PAGE_ROW_LIMIT=200
DASHBOARD_AUCTION_INSIGHTS_ROW_LIMIT=300
DASHBOARD_CANDIDATE_SIGNAL_ROW_LIMIT=100

# PostgreSQL memory tuning used by docker-compose.vps.yml.
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=20
