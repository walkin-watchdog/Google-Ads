{
  "name": "google-ads",
  "version": "1.0.0",
  "description": "Google Ads Dashboard Backend",
  "main": "server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "bun run scripts/refresh_google_ads_data.ts --force-clear && bun run server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun --watch server.ts",
    "convert-auction-csv": "bun run scripts/convert_csv_to_json.ts",
    "db:reset": "bun run scripts/reset_db.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.11.5",
    "stemmer": "^2.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.6"
  }
}
